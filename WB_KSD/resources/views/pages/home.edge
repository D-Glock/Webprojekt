<!DOCTYPE html>
<html>
<head>
  <title>Habit Tracker - Test</title>
</head>
<body>
  <h1>Meine Gewohnheiten</h1>

  <form action="/habits/create" method="post">
    {{ csrfField() }} 
    
    <input type="text" name="name" placeholder="Gewohnheit, z.B. Wasser trinken" required>
    <select name="category">
      <option value="Gesundheit">Gesundheit</option>
      <option value="Sport">Sport</option>
      <option value="Lernen">Lernen</option>
    </select>
    <button type="submit">Speichern</button>
  </form>

  <hr>

  <ul>
    @each (habit in habits)
      <li>
        <strong>{{ habit.name }}</strong> (Kategorie: {{ habit.category }})
        
        <form action="/habits/delete/{{ habit.id }}" method="post" style="display:inline;">
          {{ csrfField() }}
          <button type="submit">Löschen</button>
        </form>

        <form action="/habits/log/{{ habit.id }}" method="post" style="display:inline;">
        {{ csrfField() }}
        <button type="submit">✅ Für heute erledigt!</button>
        </form>

      </li>
    @end
  </ul>

</body>
</html>